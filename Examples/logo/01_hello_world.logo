; ============================================
; 01 - Hello World & First Steps
; Learn: PRINT, FORWARD, RIGHT, basic drawing
; ============================================

PRINT [Welcome to Logo!]
PRINT [Logo is the language of the turtle.]
PRINT []

; Draw a simple square
PRINT [Drawing a square...]
FORWARD 100
RIGHT 90
FORWARD 100
RIGHT 90
FORWARD 100
RIGHT 90
FORWARD 100
RIGHT 90

PRINT [Square complete!]
