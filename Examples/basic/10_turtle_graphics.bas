REM ============================================
REM  10 - Turtle Graphics
REM  Learn: FORWARD, RIGHT, COLOR, shapes, art
REM ============================================

10 PRINT "Drawing with Turtle Graphics!"

20 REM Draw a colourful star
30 COLOR RED
40 FOR I = 1 TO 5
50     FORWARD 100
60     RIGHT 144
70 NEXT I

80 REM Move to draw a square
90 PENUP
100 RIGHT 90
110 FORWARD 150
120 LEFT 90
130 PENDOWN

140 REM Rainbow square
150 COLOR BLUE
160 WIDTH 3
170 FOR I = 1 TO 4
180    FORWARD 80
190    RIGHT 90
200 NEXT I

210 REM Spiral
220 PENUP
230 HOME
240 LEFT 90
250 FORWARD 150
260 PENDOWN
270 FOR I = 1 TO 36
280    SELECT CASE I MOD 6
290    CASE 0
300       COLOR RED
310    CASE 1
320       COLOR ORANGE
330    CASE 2
340       COLOR YELLOW
350    CASE 3
360       COLOR GREEN
370    CASE 4
380       COLOR BLUE
390    CASE 5
400       COLOR PURPLE
410    END SELECT
420    FORWARD I * 3
430    RIGHT 91
440 NEXT I

450 REM Hexagon
460 PENUP
470 HOME
480 FORWARD 120
490 PENDOWN
500 COLOR CYAN
510 WIDTH 2
520 FOR I = 1 TO 6
530    FORWARD 60
540    RIGHT 60
550 NEXT I

560 REM Circle approximation
570 PENUP
580 HOME
590 BACKWARD 120
600 PENDOWN
610 COLOR MAGENTA
620 WIDTH 2
630 FOR I = 1 TO 36
640    FORWARD 10
650    RIGHT 10
660 NEXT I

670 PRINT "Artwork complete!"
680 END
